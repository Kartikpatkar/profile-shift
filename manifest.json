{
  "manifest_version": 3,
  "name": "ProfileShift – Salesforce Profile to Permission Set",
  "version": "0.1.1",
  "description": "Convert Salesforce Profile permissions into deployable Permission Set metadata. Privacy-first, client-side.",
  "icons": {
    "16": "src/assets/icons/icon16.png",
    "32": "src/assets/icons/icon32.png",
    "48": "src/assets/icons/icon48.png",
    "128": "src/assets/icons/icon128.png"
  },
  "action": {
    "default_title": "ProfileShift",
    "default_icon": {
      "16": "src/assets/icons/icon16.png",
      "32": "src/assets/icons/icon32.png",
      "48": "src/assets/icons/icon48.png",
      "128": "src/assets/icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "src/sw/service-worker.js",
    "type": "module"
  },
  "permissions": ["tabs", "storage", "cookies"],
  "host_permissions": [
    "https://*.my.salesforce.com/*",
    "https://*.lightning.force.com/*",
    "https://*.salesforce.com/*",
    "https://*.force.com/*",
    "https://*.salesforce-setup.com/*",
    "https://*.my.salesforce-setup.com/*",
    "https://*.visual.force.com/*",
    "https://login.salesforce.com/*",
    "https://test.salesforce.com/*"
  ]
}
